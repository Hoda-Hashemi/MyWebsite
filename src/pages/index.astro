---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const stats = [
  ["domain", "geophysical fluids"],
  ["method", "discretized dynamics"],
  ["stack", "Fortran · CUDA · Python"],
  ["interface", "scientific AI tools"],
];

const education = [
  ["2023 — now", "M.Sc. Computational Science", "American University of Beirut", "Optimization, GPU computing, statistical learning, finite elements, vortex methods."],
  ["2019 — 2023", "B.Sc. Theoretical Physics · Minor Pure Mathematics", "American University of Beirut", "Analysis, differential equations, algebra, manifolds, probability, numerical computing."],
  ["2021 — 2022", "Exchange Program", "Pitzer College, Claremont CA", "Statistical physics, French, and R programming."],
];

const work = [
  {
    id: "qgsw",
    label: "Field 01",
    title: "QGSW dynamics",
    gloss: "quasi-geostrophic shallow-water",
    summary:
      "A vortex-in-cell model for quasi-geostrophic shallow-water flow on the sphere — resolving potential-vorticity structure and streamfunction fields.",
    detail: [
      "Vortex-in-cell (VIC): vorticity carried on particles, velocity recovered on a grid.",
      "Potential vorticity (PV) conservation and energy transfer as diagnostics of correctness.",
      "Spherical-coordinate discretization for global geophysical geometry.",
    ],
    metric: "PV residual 2.1e-4",
    href: "/notes/qgsw/",
  },
  {
    id: "mitgcm",
    label: "Field 02",
    title: "MITgcm systems",
    gloss: "MIT General Circulation Model",
    summary:
      "Simulation workflows and numerical experiments for atmosphere–ocean dynamics: reproducible runs, verification, and diagnostics.",
    detail: [
      "Build graph, run directories, and verification experiments as a reproducible system.",
      "Diagnostics and source anatomy for ocean-model operations.",
      "Tutorial reproducibility for atmosphere–ocean climate dynamics.",
    ],
    metric: "build graph 93 nodes",
    href: "/notes/mitgcm/",
  },
  {
    id: "cuda",
    label: "Field 03",
    title: "CUDA / HPC",
    gloss: "GPU high-performance computing",
    summary:
      "GPU kernels shaped around memory locality, stability, and measured throughput — including a parallel Needleman–Wunsch on CUDA + HPC.",
    detail: [
      "Reduction trees, stencils, coarsening, and occupancy optimization.",
      "Memory hierarchy and data movement as first-order design constraints.",
      "Profiling discipline: throughput measured, not assumed.",
    ],
    metric: "throughput ×38",
    href: "/notes/cuda/",
  },
  {
    id: "rag",
    label: "Field 04",
    title: "LLM + RAG tools",
    gloss: "retrieval-augmented generation",
    summary:
      "An agentic interface for MITgcm: query documentation, modify model code, and execute simulations through natural language.",
    detail: [
      "Retrieval over model code, documentation, and run logic.",
      "Natural-language interfaces that keep scientific assumptions visible.",
      "Execution surface for simulations wired to the retrieval layer.",
    ],
    metric: "retrieval k = 8",
    href: "/notes/rag/",
  },
];

const writing = [
  ["2026-07-03", "QGSW potential-vorticity structure", "Vorticity, PV conservation, and spherical-coordinate discretization for shallow-water flow.", "/notes/qgsw/", "vorticity"],
  ["2026-07-03", "MITgcm setup and model anatomy", "Build workflow, run directories, diagnostics, and verification experiments.", "/notes/mitgcm/", "verification"],
  ["2026-07-03", "CUDA / HPC implementation notes", "Kernel structure, memory hierarchy, reductions, and profiling discipline.", "/notes/cuda/", "throughput"],
  ["2026-07-03", "LLM / RAG for scientific models", "Agentic retrieval workflows for scientific-modeling documentation and code.", "/notes/rag/", "interface"],
];
---
<BaseLayout pageClass="premium-home" title="Hoda Hashemi | Computational Physics">
  <Header />
  <div class="cursor-ring" aria-hidden="true"></div>
  <main id="content">
    <!-- ============ HERO : live Navier–Stokes field ============ -->
    <section class="premium-hero" aria-label="Interactive computational ocean field">
      <canvas id="fluid-hero" class="fluid-hero" aria-hidden="true"></canvas>
      <div class="field-fog" aria-hidden="true"></div>
      <div class="hero-grain" aria-hidden="true"></div>

      <p class="eyebrow eyebrow-hero">Computational physics · ocean dynamics · numerical modeling</p>
      <h1 class="hero-title" data-resolve-text>Hoda Hashemi</h1>

      <div class="hero-copy">
        <p class="hero-line">Continuous fluid physics, resolved through visible computation.</p>
        <p>
          A research portfolio for geophysical flow — QGSW theory, MITgcm ocean
          systems, CUDA/HPC implementation, and retrieval interfaces for scientific code.
          The field above is a live Navier–Stokes solver: drag to inject vorticity.
        </p>
        <div class="hero-links">
          <a class="magnetic" href="#about">About &amp; CV</a>
          <a class="magnetic" href="#work">Research</a>
          <a class="magnetic" href="/assets/CV_HodaHashemi.pdf" download>Download CV</a>
          <a class="magnetic" href="https://github.com/Hoda-Hashemi" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>

      <aside class="hero-readout" aria-label="Live solver readout">
        <div><span>solver</span><strong>Navier–Stokes</strong></div>
        <div><span>grid</span><strong id="res-readout">—</strong></div>
        <div><span>frame</span><strong id="frame-readout">00000</strong></div>
        <label class="density-control" for="grid-density">
          <span>lattice density <strong id="grid-readout">26</strong></span>
          <input id="grid-density" type="range" min="10" max="60" value="26" />
        </label>
      </aside>

      <div class="hero-stat-strip" aria-label="Research summary">
        {stats.map(([label, value]) => (
          <span><small>{label}</small>{value}</span>
        ))}
      </div>
      <a class="scroll-cue magnetic" href="#about">Scroll / resolve ↓</a>
    </section>

    <!-- ============ ABOUT / CV : the legible anchor ============ -->
    <section id="about" class="about-anchor">
      <div class="about-intro panel-resolve">
        <p class="eyebrow">Profile</p>
        <h2 class="section-title">Modeling continuous fluids through discrete computation.</h2>
      </div>
      <div class="about-layout">
        <div class="about-lede panel-resolve">
          <p>
            Hoda Hashemi is a computational physicist working in ocean dynamics and
            numerical modeling. The core thread is <em>discretization</em> — translating
            continuous geophysical flow into stable, inspectable computational fields.
          </p>
          <p>
            Current work represents vorticity dynamics, potential-vorticity conservation,
            and energy transfer in geophysical flows through numerical frameworks and
            research software — plus interfaces that make advanced simulation tools easier to use.
          </p>
          <div class="about-actions">
            <a class="cta primary magnetic" href="/assets/CV_HodaHashemi.pdf" download>Download CV (PDF)</a>
            <a class="cta magnetic" href="/CV/">Open full CV</a>
          </div>
        </div>

        <div class="about-timeline panel-resolve">
          <p class="eyebrow">Education</p>
          <ol class="timeline">
            {education.map(([time, title, place, note]) => (
              <li>
                <time>{time}</time>
                <div>
                  <h3>{title}</h3>
                  <p class="place">{place}</p>
                  <p class="note">{note}</p>
                </div>
              </li>
            ))}
          </ol>
          <div class="about-facts">
            <div><small>current</small>Graduate Research Assistant — Microflows &amp; Microscale Heat Transfer Lab, AUB</div>
            <div><small>stack</small>Python · Julia · Fortran · C/C++ · CUDA · MATLAB · FreeFem++ · MITgcm · Slurm</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WORK / RESEARCH : expanding instrument cards ============ -->
    <section id="work" class="work-section">
      <div class="section-drift" data-drift="70" aria-hidden="true"></div>
      <div class="section-intro panel-resolve">
        <p class="eyebrow">Selected research</p>
        <h2 class="section-title">Four instruments in the same lab.</h2>
        <p class="section-sub">Each card assembles from the grid as it enters view. Select one to expand its method.</p>
      </div>
      <div class="work-grid">
        {work.map((item, i) => (
          <article class="work-card" data-panel={item.id} style={`--i:${i}`}>
            <div class="work-visual">
              <canvas class="instrument-canvas" data-kind={item.id} aria-hidden="true"></canvas>
              <span class="work-signal">{item.metric}</span>
            </div>
            <div class="work-copy">
              <p class="eyebrow">{item.label}</p>
              <h3 class="work-title">
                <button
                  class="work-toggle"
                  type="button"
                  aria-expanded="false"
                  aria-controls={`work-detail-${item.id}`}
                >
                  {item.title}
                  <span class="work-expand" aria-hidden="true">expand ↕</span>
                </button>
              </h3>
              <p class="work-gloss">{item.gloss}</p>
              <p class="work-summary">{item.summary}</p>
              <div class="work-detail" id={`work-detail-${item.id}`}>
                <ul>
                  {item.detail.map((d) => <li>{d}</li>)}
                </ul>
                <a class="text-link magnetic" href={item.href}>Open research note →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ PRODUCTS : live GitHub data ============ -->
    <section id="products" class="products-section">
      <div class="section-drift alt" data-drift="-60" aria-hidden="true"></div>
      <div class="section-intro panel-resolve">
        <p class="eyebrow">Products · shipped repositories</p>
        <h2 class="section-title">Software, pulled live from GitHub.</h2>
        <p class="section-sub">
          Repositories fetched client-side from the GitHub API and cached locally.
          The MITgcm Fortran fork is pinned.
        </p>
      </div>
      <div id="products-grid" class="products-grid is-loading" aria-live="polite">
        <div class="product-skeleton"></div>
        <div class="product-skeleton"></div>
        <div class="product-skeleton"></div>
      </div>
      <noscript>
        <div class="product-fallback">
          <p>Live repository data requires JavaScript.</p>
          <a class="text-link" href="https://github.com/Hoda-Hashemi" target="_blank" rel="noopener noreferrer">
            View all repositories on GitHub →
          </a>
        </div>
      </noscript>
      <a class="text-link magnetic products-all" href="https://github.com/Hoda-Hashemi" target="_blank" rel="noopener noreferrer">
        All repositories on GitHub →
      </a>
    </section>

    <!-- ============ WRITING : hover-reveal previews ============ -->
    <section id="writing" class="writing-section">
      <div class="section-drift" data-drift="80" aria-hidden="true"></div>
      <div class="section-intro panel-resolve">
        <p class="eyebrow">Writing · notebook</p>
        <h2 class="section-title">Notes after the field resolves.</h2>
      </div>
      <div class="article-list panel-resolve">
        {writing.map(([date, title, blurb, href, tag], i) => (
          <a class="article-row" href={href} style={`--i:${i}`}>
            <time datetime={date}>{date}</time>
            <strong class="article-title">{title}</strong>
            <span class="article-blurb">{blurb}</span>
            <span class="article-arrow" aria-hidden="true">→</span>
            <div class="article-preview" aria-hidden="true">
              <div class="preview-field" data-kind={tag}></div>
              <p>{blurb}</p>
              <span class="preview-tag">{tag}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
