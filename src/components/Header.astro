---
const links = [
  ["About", "/#about"],
  ["Research", "/#work"],
  ["Products", "/#products"],
  ["Writing", "/#writing"],
  ["CV", "/CV/"]
];
---
<header class="site-header">
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand-lockup magnetic" href="/" aria-label="Hoda Hashemi home">
      <img class="mark-on-dark" src="/brand/mark-teal.svg" alt="" width="34" height="34" />
      <img class="mark-on-light" src="/brand/mark-ink.svg" alt="" width="34" height="34" />
      <span>Hoda Hashemi</span>
    </a>
    <div class="nav-center">
      {links.map(([label, href]) => <a class="magnetic" href={href}>{label}</a>)}
    </div>
    <div class="nav-social" aria-label="External profile links">
      <a class="magnetic" href="https://www.linkedin.com/in/hoda-hashemi-630a33204/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="magnetic" href="https://github.com/Hoda-Hashemi" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>
</header>
